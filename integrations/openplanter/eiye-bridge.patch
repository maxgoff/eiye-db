diff --git a/agent/tools.py b/agent/tools.py
index 86a9e5c..df8902c 100644
--- a/agent/tools.py
+++ b/agent/tools.py
@@ -885,3 +885,72 @@ class WorkspaceTools:
             "total": len(pages),
         }
         return self._clip(json.dumps(output, indent=2, ensure_ascii=True), self.max_file_chars)
+
+    # ------------------------------------------------------------------
+    # eiye_db bridge — governed data access via the eiye_db REST gateway.
+    # Base URL from EIYE_DB_URL (default http://localhost:8000/api/v1);
+    # optional X-API-Key from EIYE_DB_API_KEY. Never sends include_pii, so
+    # eiye_db always redacts PII and audits every call.
+    # ------------------------------------------------------------------
+    def _eiye_request(self, method: str, path: str, payload: dict[str, Any] | None = None) -> Any:
+        base = (os.environ.get("EIYE_DB_URL") or "http://localhost:8000/api/v1").rstrip("/")
+        url = base + path
+        headers = {"Accept": "application/json"}
+        data = None
+        if payload is not None:
+            data = json.dumps(payload).encode("utf-8")
+            headers["Content-Type"] = "application/json"
+        key = os.environ.get("EIYE_DB_API_KEY")
+        if key:
+            headers["X-API-Key"] = key
+        req = urllib.request.Request(url=url, data=data, headers=headers, method=method)
+        try:
+            with urllib.request.urlopen(req, timeout=self.command_timeout_sec) as resp:
+                raw = resp.read().decode("utf-8", errors="replace")
+        except urllib.error.HTTPError as exc:
+            body = exc.read().decode("utf-8", errors="replace")
+            raise ToolError(f"eiye_db HTTP {exc.code}: {body}") from exc
+        except urllib.error.URLError as exc:
+            raise ToolError(f"eiye_db connection error ({url}): {exc}") from exc
+        except OSError as exc:
+            raise ToolError(f"eiye_db network error: {exc}") from exc
+        try:
+            return json.loads(raw)
+        except json.JSONDecodeError as exc:
+            raise ToolError(f"eiye_db returned non-JSON payload: {raw[:500]}") from exc
+
+    def eiye_db_list_datasources(self) -> str:
+        try:
+            parsed = self._eiye_request("GET", "/surface/sources")
+        except Exception as exc:
+            return f"eiye_db_list_datasources failed: {exc}"
+        return self._clip(json.dumps(parsed, indent=2, ensure_ascii=True), self.max_file_chars)
+
+    def eiye_db_get_schema(self, datasource_id: str) -> str:
+        datasource_id = datasource_id.strip()
+        if not datasource_id:
+            return "eiye_db_get_schema requires datasource_id"
+        try:
+            parsed = self._eiye_request("POST", f"/datasources/{datasource_id}/discover")
+        except Exception as exc:
+            return f"eiye_db_get_schema failed: {exc}"
+        return self._clip(json.dumps(parsed, indent=2, ensure_ascii=True), self.max_file_chars)
+
+    def eiye_db_query(self, datasource_id: str, request: str, limit: int | None = None) -> str:
+        datasource_id = datasource_id.strip()
+        if not datasource_id:
+            return "eiye_db_query requires datasource_id"
+        try:
+            request_obj = json.loads(request) if isinstance(request, str) else request
+        except json.JSONDecodeError as exc:
+            return f"eiye_db_query: request must be a JSON object string: {exc}"
+        if not isinstance(request_obj, dict):
+            return "eiye_db_query: request must be a JSON object"
+        payload: dict[str, Any] = {"datasource_id": datasource_id, "request": request_obj}
+        if limit is not None:
+            payload["limit"] = limit
+        try:
+            parsed = self._eiye_request("POST", "/query", payload)
+        except Exception as exc:
+            return f"eiye_db_query failed: {exc}"
+        return self._clip(json.dumps(parsed, indent=2, ensure_ascii=True), self.max_file_chars)
